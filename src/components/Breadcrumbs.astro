---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Хлебные крошки" class="max-w-3xl mx-auto px-4 pt-4">
  <ol
    class="flex flex-wrap text-sm text-gray-500"
    itemscope
    itemtype="https://schema.org/BreadcrumbList"
  >
    {
      items.map((item, i) => {
        const isLast = i === items.length - 1;
        return (
          <li
            class="flex items-center"
            itemprop="itemListElement"
            itemscope
            itemtype="https://schema.org/ListItem"
          >
            {item.href && !isLast ? (
              <a href={item.href} class="text-blue-600 hover:underline" itemprop="item">
                <span itemprop="name">{item.label}</span>
              </a>
            ) : (
              <span itemprop="name">{item.label}</span>
            )}
            <meta itemprop="position" content={String(i + 1)} />
            {!isLast && <span class="mx-2 text-gray-300">/</span>}
          </li>
        );
      })
    }
  </ol>
</nav>
