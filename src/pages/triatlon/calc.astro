---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="Калькулятор триатлона"
  description="Калькулятор темпа и финишного времени для триатлона. Рассчитайте свой результат для Ironman, Half-Ironman, Olympic, Sprint и Super Sprint."
>
  <Header />
  <main class="max-w-lg mx-auto px-4 py-8 sm:py-12">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Калькулятор триатлона</h1>
    <p class="mt-2 text-sm text-gray-500">
      Рассчитайте финишное время и темп для любой дистанции триатлона
    </p>

    <div id="tricalc" class="mt-6 space-y-5">
      <!-- Presets -->
      <div>
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Дистанция</label>
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-1.5">
          {['Ironman', 'Half', 'Olympic', 'Sprint', 'Super', 'Своя'].map((d) => (
            <button
              class="distance-btn px-2 py-2 rounded-lg text-xs sm:text-sm font-medium border border-gray-200 bg-white text-gray-600 hover:border-blue-300 hover:text-blue-600 transition-colors active:bg-blue-50"
              data-distance={d}
            >
              {d}
            </button>
          ))}
        </div>
      </div>

      <!-- Disciplines -->
      <div class="space-y-4">
        <!-- Swim -->
        <div class="bg-gray-50 rounded-xl p-4 space-y-3">
          <div class="flex items-center gap-2"><span class="text-2xl">🏊</span><span class="text-sm font-medium text-gray-700">Плавание</span></div>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="block text-xs text-gray-400 mb-1">Дистанция, км</label>
              <input type="number" id="swim-dist" value="3.86" step="0.01" min="0" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Темп /100м</label>
              <input type="text" id="swim-pace" value="2:00" placeholder="мм:сс" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Время</label>
              <input type="text" id="swim-time" value="" placeholder="ч:мм:сс" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
            </div>
          </div>
        </div>

        <!-- Bike -->
        <div class="bg-gray-50 rounded-xl p-4 space-y-3">
          <div class="flex items-center gap-2"><span class="text-2xl">🚴</span><span class="text-sm font-medium text-gray-700">Велосипед</span></div>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="block text-xs text-gray-400 mb-1">Дистанция, км</label>
              <input type="number" id="bike-dist" value="180.25" step="0.1" min="0" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Скорость, км/ч</label>
              <input type="number" id="bike-speed" value="30" step="0.5" min="0" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Время</label>
              <input type="text" id="bike-time" value="" placeholder="ч:мм:сс" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
            </div>
          </div>
        </div>

        <!-- Run -->
        <div class="bg-gray-50 rounded-xl p-4 space-y-3">
          <div class="flex items-center gap-2"><span class="text-2xl">🏃</span><span class="text-sm font-medium text-gray-700">Бег</span></div>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="block text-xs text-gray-400 mb-1">Дистанция, км</label>
              <input type="number" id="run-dist" value="42.2" step="0.01" min="0" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Темп /км</label>
              <input type="text" id="run-pace" value="5:00" placeholder="мм:сс" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Время</label>
              <input type="text" id="run-time" value="" placeholder="ч:мм:сс" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
            </div>
          </div>
        </div>
      </div>

      <!-- Transitions -->
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-gray-50 rounded-xl p-4">
          <label class="block text-xs text-gray-400 mb-1">T1 (🏊→🚴)</label>
          <input type="text" id="t1" value="5:00" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <label class="block text-xs text-gray-400 mb-1">T2 (🚴→🏃)</label>
          <input type="text" id="t2" value="3:00" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base bg-white text-center" />
        </div>
      </div>

      <!-- Results -->
      <div class="bg-blue-50 rounded-2xl p-5">
        <div class="grid grid-cols-1 gap-3">
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500">🏊 Плавание</span>
            <span id="res-swim" class="text-lg font-bold text-gray-900">1:17:12</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500">🚴 Велосипед + T1</span>
            <span id="res-bike" class="text-lg font-bold text-gray-900">6:05:30</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500">🏃 Бег + T2</span>
            <span id="res-run" class="text-lg font-bold text-gray-900">3:33:00</span>
          </div>
          <div class="pt-3 mt-1 border-t border-blue-200 flex justify-between items-center">
            <span class="text-sm font-semibold text-gray-700">🏁 Финиш</span>
            <span id="res-total" class="text-2xl font-bold text-blue-600">11:03:42</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const presets = {
      'Ironman': { swim: 3.86, bike: 180.25, run: 42.2 },
      'Half': { swim: 1.9, bike: 90, run: 21.1 },
      'Olympic': { swim: 1.5, bike: 40, run: 10 },
      'Sprint': { swim: 0.75, bike: 20, run: 5 },
      'Super': { swim: 0.4, bike: 10, run: 2.5 },
    };

    // Track which was last edited: 'pace' | 'time'
    const lastEdited: Record<string, string> = { swim: 'pace', bike: 'speed', run: 'pace' };

    function parseTime(str: string): number {
      const parts = str.split(':').map(Number);
      if (parts.length === 2) return parts[0] * 60 + parts[1];
      if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
      return 0;
    }

    function formatTime(sec: number): string {
      if (sec <= 0 || isNaN(sec)) return '--';
      const h = Math.floor(sec / 3600);
      const m = Math.floor((sec % 3600) / 60);
      const s = Math.floor(sec % 60);
      if (h > 0) return `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      return `${m}:${String(s).padStart(2, '0')}`;
    }

    function formatPace(secTotal: number, perUnit: number): string {
      if (secTotal <= 0 || perUnit <= 0 || isNaN(secTotal) || isNaN(perUnit)) return '';
      const paceSec = secTotal / perUnit;
      const m = Math.floor(paceSec / 60);
      const s = Math.floor(paceSec % 60);
      return `${m}:${String(s).padStart(2, '0')}`;
    }

    function get(id: string): HTMLInputElement { return document.getElementById(id) as HTMLInputElement; }

    function calc() {
      // Swim
      const sDist = parseFloat(get('swim-dist').value) || 0;
      let sPace = parseTime(get('swim-pace').value);
      let sTime = parseTime(get('swim-time').value);

      if (lastEdited.swim === 'time' && sTime > 0 && sDist > 0) {
        sPace = (sTime / (sDist * 10));
        get('swim-pace').value = formatPace(sTime, sDist * 10);
      } else if (sDist > 0 && sPace > 0) {
        sTime = sDist * 10 * sPace;
        get('swim-time').value = formatTime(sTime);
      }

      // Bike
      const bDist = parseFloat(get('bike-dist').value) || 0;
      let bSpeed = parseFloat(get('bike-speed').value) || 0;
      let bTime = parseTime(get('bike-time').value);

      if (lastEdited.bike === 'time' && bTime > 0 && bDist > 0) {
        bSpeed = (bDist / bTime) * 3600;
        get('bike-speed').value = bSpeed.toFixed(1);
      } else if (bDist > 0 && bSpeed > 0) {
        bTime = (bDist / bSpeed) * 3600;
        get('bike-time').value = formatTime(bTime);
      }

      // Run
      const rDist = parseFloat(get('run-dist').value) || 0;
      let rPace = parseTime(get('run-pace').value);
      let rTime = parseTime(get('run-time').value);

      if (lastEdited.run === 'time' && rTime > 0 && rDist > 0) {
        rPace = rTime / rDist;
        get('run-pace').value = formatPace(rTime, rDist);
      } else if (rDist > 0 && rPace > 0) {
        rTime = rDist * rPace;
        get('run-time').value = formatTime(rTime);
      }

      // Transitions
      const t1 = parseTime(get('t1').value);
      const t2 = parseTime(get('t2').value);

      get('res-swim').textContent = formatTime(sTime);
      get('res-bike').textContent = formatTime(bTime + t1);
      get('res-run').textContent = formatTime(rTime + t2);
      get('res-total').textContent = formatTime(sTime + bTime + rTime + t1 + t2);
    }

    // Track edits
    get('swim-pace').addEventListener('input', () => { lastEdited.swim = 'pace'; calc(); });
    get('swim-time').addEventListener('input', () => { lastEdited.swim = 'time'; calc(); });
    get('bike-speed').addEventListener('input', () => { lastEdited.bike = 'speed'; calc(); });
    get('bike-time').addEventListener('input', () => { lastEdited.bike = 'time'; calc(); });
    get('run-pace').addEventListener('input', () => { lastEdited.run = 'pace'; calc(); });
    get('run-time').addEventListener('input', () => { lastEdited.run = 'time'; calc(); });

    // Distance changes: respect lastEdited
    get('swim-dist').addEventListener('input', calc);
    get('bike-dist').addEventListener('input', calc);
    get('run-dist').addEventListener('input', calc);
    get('t1').addEventListener('input', calc);
    get('t2').addEventListener('input', calc);

    // Preset buttons
    document.querySelectorAll('.distance-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.distance-btn').forEach((b) => b.classList.remove('bg-blue-50', 'border-blue-300', 'text-blue-700'));
        btn.classList.add('bg-blue-50', 'border-blue-300', 'text-blue-700');
        const preset = presets[(btn as HTMLElement).dataset.distance!];
        if (preset) {
          get('swim-dist').value = String(preset.swim);
          get('bike-dist').value = String(preset.bike);
          get('run-dist').value = String(preset.run);
        }
        calc();
      });
    });

    calc();
  </script>

  <Footer />
</Base>
